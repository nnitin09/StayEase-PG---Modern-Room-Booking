# Stripe API Keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Cloudinary API Keys (For permanent image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PostgreSQL Database URL (e.g., from Supabase or Neon)
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# Email Settings for OTP (e.g. Gmail App Password)
# NOTE: If these are not provided, the app will log OTP to the console for testing
EMAIL_USER=
EMAIL_PASS=
